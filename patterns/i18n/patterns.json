{
  "version": "1.0.0",
  "description": "International PII/ID patterns for redaction",
  "patterns": {
    "JP": {
      "name": "Japan",
      "flag": "🇯🇵",
      "items": {
        "my_number": {
          "label": "My Number (マイナンバー)",
          "regex": "\\b\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}\\b",
          "placeholder": "[REDACTED_JP_MYNUMBER]",
          "validate": "luhn12"
        },
        "phone": {
          "label": "Phone Number",
          "regex": "(?:\\+81[\\s-]?|0)(?:[1-9]\\d{1,4}[\\s-]?\\d{1,4}[\\s-]?\\d{4}|[789]0[\\s-]?\\d{4}[\\s-]?\\d{4})",
          "placeholder": "[REDACTED_JP_PHONE]"
        },
        "postal_code": {
          "label": "Postal Code",
          "regex": "\\b〒?\\d{3}[\\s-]?\\d{4}\\b",
          "placeholder": "[REDACTED_JP_POSTAL]"
        },
        "residence_card": {
          "label": "Residence Card",
          "regex": "\\b[A-Z]\\d{12}\\b",
          "placeholder": "[REDACTED_JP_RESIDENCE]"
        }
      }
    },
